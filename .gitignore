# =============================================================================
# Supermarket Price Tracker — .gitignore
# =============================================================================

# ── Entorno y secretos ────────────────────────────────────────────────
.env
.env.*
!example.env

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Entornos virtuales ────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Pytest y coverage ────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ── Exports temporales (CSVs de scrapers) ────────────────────────────
export/
*.csv

# ── Logs ─────────────────────────────────────────────────────────────
logs/
*.log

# ── Playwright ───────────────────────────────────────────────────────
playwright-report/
test-results/

# ── IDEs y editores ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Jupyter ──────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Streamlit ────────────────────────────────────────────────────────
.streamlit/secrets.toml
