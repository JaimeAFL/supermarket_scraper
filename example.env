# =============================================================================
# Supermarket Price Tracker — Variables de entorno
# =============================================================================
# Copia este archivo como .env y rellena los valores.
# Consulta docs/guia_env.md para instrucciones detalladas.
# =============================================================================

# ── Código postal ─────────────────────────────────────────────────────
# Determina la tienda/almacén que sirve los precios.
# Los precios pueden variar según la zona geográfica.
CODIGO_POSTAL=28001

# ── Cookie de Carrefour (obligatoria) ─────────────────────────────────
# La única cookie que NO se puede obtener automáticamente.
# Ver docs/guia_env.md para instrucciones paso a paso.
COOKIE_CARREFOUR=TU_COOKIE_DE_CARREFOUR_AQUI

# ── Cookie de Dia (opcional) ──────────────────────────────────────────
# Se obtiene automáticamente con Playwright. Solo rellena esto como
# fallback si la obtención automática falla en tu entorno.
COOKIE_DIA=

# ── Ruta de la base de datos (opcional) ───────────────────────────────
# Por defecto: database/supermercados.db (relativa al proyecto).
# Solo cambia esto si necesitas usar una ruta personalizada.
# SUPERMARKET_DB_PATH=/ruta/absoluta/a/tu/supermercados.db
